# Copy to `.env` in this folder (Screen 1) — Vite reads env from the app root.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy anon key also supported:
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Groq runs server-side only — do NOT add VITE_GROQ_API_KEY to the client.
# 1. Supabase Dashboard → Authentication → Third-Party → enable Firebase
# 2. Set secret: supabase secrets set GROQ_API_KEY=your-groq-key
# 3. Run migrations 007_firebase_rls.sql and 008_edge_rate_limits.sql in Supabase SQL Editor
# 4. Deploy functions: npm run deploy:functions
