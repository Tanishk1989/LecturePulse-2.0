PORT=5000

# Supabase Postgres
# Local / Render runtime: direct connection on port 5432
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Optional — only needed if you use `prisma migrate` against production
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

GROQ_API_KEY="your-groq-api-key"
# Get a free key at https://console.groq.com/keys — required for transcription and AI notes.

# Local dev: path to JSON file
FIREBASE_SERVICE_ACCOUNT_PATH="firebase-service-account.json"

# Render: paste the full service-account JSON as one line (no line breaks)
# FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'
