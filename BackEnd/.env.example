PORT=5000

# Supabase → Connect → URI (Session mode or Direct). Paste on Render as DATABASE_URL.
# If the password contains @ # % etc., URL-encode them (e.g. @ → %40, # → %23).
# Example shape (replace with your values):
# DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

DATABASE_URL=

GROQ_API_KEY=

# On Render: paste the full service account JSON as one line (not a file path).
FIREBASE_SERVICE_ACCOUNT_KEY=

# Local dev only — use firebase-service-account.json path instead of FIREBASE_SERVICE_ACCOUNT_KEY
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

PUBLIC_BASE_URL=https://lecturepulse.onrender.com
