datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Lecture {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  fileType  String   @map("file_type")
  fileUrl   String   @map("file_url")
  duration  Int?
  status    String   @default("uploaded")
  favorite  Boolean  @default(false)
  source    String   @default("upload")
  subject   String?
  kgStatus  String   @default("pending") @map("kg_status")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  transcripts   Transcript[]
  lectureNotes  LectureNote[]
  flashcards    Flashcard[]
  kgConcepts    KgConcept[]
  kgLinks       KgLink[]
  studySessions StudySession[]

  @@map("lectures")
}

model Transcript {
  id              String   @id @default(uuid())
  lectureId       String   @map("lecture_id")
  userId          String   @map("user_id")
  fullText        String   @map("full_text")
  rawText         String?  @map("raw_text")
  segments        Json     @default("[]")
  status          String   @default("processing")
  errorMessage    String?  @map("error_message")
  durationSeconds Int?     @map("duration_seconds")
  language        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model LectureNote {
  id              String   @id @default(uuid())
  lectureId       String   @map("lecture_id")
  userId          String   @map("user_id")
  summary         String?
  keyConcepts     Json     @default("[]") @map("key_concepts")
  importantPoints Json     @default("[]") @map("important_points")
  definitions     Json     @default("[]") @map("definitions")
  examples        Json     @default("[]") @map("examples")
  mindMap         Json     @default("{}") @map("mind_map")
  questions       Json     @default("[]") @map("questions")
  examTips        Json     @default("{}") @map("exam_tips")
  status          String   @default("generating")
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@map("lecture_notes")
}

model Flashcard {
  id              String    @id @default(uuid())
  lectureId       String    @map("lecture_id")
  userId          String    @map("user_id")
  front           String
  back            String
  conceptId       String?   @map("concept_id")
  conceptName     String?   @map("concept_name")
  status          String    @default("new")
  reviewAttempts  Int       @default(0) @map("review_attempts")
  correctAttempts Int       @default(0) @map("correct_attempts")
  nextReviewAt    DateTime? @map("next_review_at")
  lastReviewedAt  DateTime? @map("last_reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  lecture Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  concept KgConcept? @relation(fields: [conceptId], references: [id], onDelete: SetNull)

  @@map("flashcards")
}

model KgConcept {
  id          String   @id @default(uuid())
  lectureId   String   @map("lecture_id")
  userId      String   @map("user_id")
  name        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  lecture      Lecture              @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  linksFrom    KgLink[]             @relation("KgLinkFrom")
  linksTo      KgLink[]             @relation("KgLinkTo")
  flashcards   Flashcard[]
  quizAttempts ConceptQuizAttempt[]

  @@unique([lectureId, name])
  @@map("kg_concepts")
}

model KgLink {
  id            String   @id @default(uuid())
  lectureId     String   @map("lecture_id")
  userId        String   @map("user_id")
  fromConceptId String   @map("from_concept_id")
  toConceptId   String   @map("to_concept_id")
  createdAt     DateTime @default(now()) @map("created_at")

  lecture     Lecture   @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  fromConcept KgConcept @relation("KgLinkFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept   KgConcept @relation("KgLinkTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@map("kg_links")
}

model ConceptQuizAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  conceptId      String   @map("concept_id")
  lectureId      String   @map("lecture_id")
  question       String
  selectedAnswer String   @map("selected_answer")
  correctAnswer  String   @map("correct_answer")
  isCorrect      Boolean  @map("is_correct")
  createdAt      DateTime @default(now()) @map("created_at")

  concept KgConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@map("concept_quiz_attempts")
}

model AiFeedback {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  contentType String   @map("content_type")
  contentId   String?  @map("content_id")
  lectureId   String   @map("lecture_id")
  subject     String?
  feedback    String   @map("feedback")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ai_feedback")
}

model UserProfile {
  userId              String   @id @map("user_id")
  course              String?
  studyGoal           String?  @map("study_goal")
  tutorStyle          String?  @default("balanced") @map("tutor_style")
  summaryLength       String?  @default("auto") @map("summary_length")
  flashcardDifficulty String?  @default("mixed") @map("flashcard_difficulty")
  dailyReminder       Boolean  @default(false) @map("daily_reminder")
  dailyReminderTime   String?  @map("daily_reminder_time")
  streakAlerts        Boolean  @default(false) @map("streak_alerts")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model StudySession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  lectureId String   @map("lecture_id")
  duration  Int      @default(0) // duration in seconds
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}

model UserStreak {
  userId            String    @id @map("user_id")
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  freezeCount       Int       @default(1) @map("freeze_count")
  lastActiveDate    DateTime? @map("last_active_date")
  lastReplenishedAt DateTime  @default(now()) @map("last_replenished_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("user_streaks")
}

model FreezeHistory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  frozenDate DateTime @map("frozen_date")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("freeze_history")
}

model Exam {
  userId    String   @id @map("user_id")
  title     String
  date      DateTime
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("exams")
}
